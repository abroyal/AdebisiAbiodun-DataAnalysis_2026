# STEP 3: Check for missing values
# ===============================
colSums(is.na(df))   # Number of missing values per column
sum(is.na(df))       # Total missing values

# ===============================
# STEP 4: Prepare data for MCAR test
# (LittleMCAR works best with numeric variables)
# ===============================
# Keep only numeric columns
data_numeric <- df %>% select(where(is.numeric))

# Optional: remove columns with no missing values (improves test stability)
data_numeric <- data_numeric[, colSums(is.na(data_numeric)) > 0]

# ===============================
# STEP 5: Run Little's MCAR Test
# ===============================
mcar_test <- LittleMCAR(data_numeric)

# View results
print(mcar_test)

# ===============================
# STEP 6: Extract p-value
# ===============================
p_value <- mcar_test$p.value
cat("P-value:", p_value, "\n")

# ===============================
# STEP 7: Decision Rule
# ===============================
if (p_value > 0.05) {
  cat("Conclusion: Fail to reject H0 — Data is likely MCAR\n")
} else {
  cat("Conclusion: Reject H0 — Data is NOT MCAR (MAR or MNAR)\n")
}
